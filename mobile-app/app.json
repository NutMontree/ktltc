{
  "expo": {
    "name": "mobile-app",
    "slug": "mobile-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "UIBackgroundModes": [
          "location",
          "fetch"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "ktltc.tracking"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "แอปจำเป็นต้องเข้าถึงตำแหน่งของคุณเพื่อใช้งานระบบแจ้งเตือนเมื่อออกนอกสถานศึกษา",
          "locationAlwaysPermission": "แอปจำเป็นต้องติดตามตำแหน่งของคุณในเบื้องหลัง เพื่อส่งข้อมูลให้ครูผู้ดูแลทราบแบบเรียลไทม์",
          "isAndroidBackgroundLocationEnabled": true
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "e46b1562-4e76-474b-a53c-b1200b0aa098"
      }
    }
  }
}
